{
  "name": "ptitpote",
  "private": true,
  "version": "1.0.0",
  "description": "a discord bot",
  "main": "api.js",
  "type": "module",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "start:api": "node dist/src/api.js",
    "start:gateway": "node dist/src/gateway.js",
    "register": "node dist/src/register.js",
    "dev:api": "nodemon -q dist/src/api.js",
    "dev:gateway": "nodemon -q dist/src/gateway.js",
    "test": "vitest --config ./vitest.config.ts run",
    "build": "tsc --pretty",
    "lint": "prettier . --check"
  },
  "mikro-orm": {
    "useTsNode": false,
    "configPaths": [
      "./dist/src/mikro-orm.config.js"
    ]
  },
  "author": "GTSpray",
  "license": "MIT",
  "dependencies": {
    "@mikro-orm/cli": "^7.0.10",
    "@mikro-orm/core": "^7.0.10",
    "@mikro-orm/decorators": "^7.0.10",
    "@mikro-orm/mariadb": "^7.0.10",
    "@mikro-orm/migrations": "^7.0.10",
    "bufferutil": "^4.1.0",
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "reflect-metadata": "^0.2.2",
    "utf-8-validate": "^6.0.6",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "discord-api-types": "^0.38.45",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.1.14",
    "prettier": "3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
