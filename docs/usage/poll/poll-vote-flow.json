{
  "$schema": "../schema/scenario.schema.json",
  "id": "poll-vote-flow",
  "title": "Poll — voter (Je vote!)",
  "doc": "docs/usage/poll/poll.md",
  "chrome": {
    "guild": {
      "name": "Serveur de démo"
    },
    "channel": {
      "name": "général",
      "type": "text"
    },
    "membersOnline": 12,
    "viewer": {
      "name": "You",
      "status": "Online"
    }
  },
  "defaults": {
    "botPendingText": "Envoi de la commande..."
  },
  "actions": [
    {
      "type": "wait",
      "ms": 1200
    },
    {
      "type": "applyState",
      "responseDelayMs": 0,
      "layers": {
        "messages": [
          {
            "author": {
              "name": "P'tit Pote",
              "bot": true,
              "avatarUrl": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote.png"
            },
            "timestamp": "15:10",
            "interaction": {
              "type": 4,
              "data": {
                "flags": 32768,
                "components": [
                  {
                    "type": 9,
                    "components": [
                      {
                        "type": 10,
                        "content": "# Oyé Oyé !\n-# Le staff réclame votre attention pour un sondage!"
                      },
                      {
                        "type": 10,
                        "content": "Repas de fin d'année"
                      }
                    ],
                    "accessory": {
                      "type": 11,
                      "media": {
                        "url": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote-sam.png"
                      }
                    }
                  },
                  {
                    "type": 14,
                    "divider": true,
                    "spacing": 1
                  },
                  {
                    "type": 1,
                    "components": [
                      {
                        "type": 2,
                        "style": 1,
                        "label": "Je vote!"
                      },
                      {
                        "type": 2,
                        "style": 2,
                        "label": "Compte rendu"
                      }
                    ]
                  }
                ]
              }
            }
          }
        ]
      },
      "holdMs": 1600
    },
    {
      "type": "clickButton",
      "label": "Je vote!"
    },
    {
      "type": "openModal",
      "modal": {
        "type": 9,
        "author": {
          "name": "P'tit Pote",
          "bot": true,
          "avatarUrl": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote.png"
        },
        "data": {
          "title": "Repas de fin d'année",
          "components": [
            {
              "type": 18,
              "label": "Quel jour ?",
              "description": "Votez pour la date qui vous arrange",
              "component": {
                "type": 3,
                "custom_id": "q1",
                "placeholder": "Choisis...",
                "options": [
                  {
                    "label": "mercredi",
                    "value": "choice-mer",
                    "emoji": {
                      "name": "▪️"
                    }
                  },
                  {
                    "label": "jeudi",
                    "value": "choice-jeu",
                    "emoji": {
                      "name": "▪️"
                    }
                  },
                  {
                    "label": "vendredi",
                    "value": "choice-ven",
                    "emoji": {
                      "name": "▪️"
                    }
                  }
                ]
              }
            },
            {
              "type": 18,
              "label": "avez vous des alergenes",
              "component": {
                "type": 4,
                "custom_id": "q2",
                "style": 2,
                "required": true
              }
            }
          ]
        }
      }
    },
    {
      "type": "fillModal",
      "values": {
        "q1": "choice-jeu",
        "q2": "Non, aucune"
      },
      "msPerField": 160
    },
    {
      "type": "wait",
      "ms": 800
    },
    {
      "type": "submitModal"
    },
    {
      "type": "showEphemeral",
      "ephemeral": {
        "author": {
          "name": "P'tit Pote",
          "bot": true,
          "avatarUrl": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote.png"
        },
        "type": 4,
        "data": {
          "flags": 64,
          "content": "A voté!"
        }
      }
    },
    {
      "type": "wait",
      "ms": 2500
    }
  ],
  "output": {
    "directory": "docs/usage/poll",
    "prefix": "poll-vote-flow",
    "video": true
  }
}
