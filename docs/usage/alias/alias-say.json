{
  "$schema": "../schema/scenario.schema.json",
  "id": "alias-say",
  "title": "Alias — poster un message stocké",
  "doc": "docs/usage/alias/alias.md",
  "chrome": {
    "guild": {
      "name": "Serveur de démo"
    },
    "channel": {
      "name": "général",
      "type": "text"
    },
    "membersOnline": 8,
    "viewer": {
      "name": "Modo",
      "status": "Online"
    }
  },
  "defaults": {
    "botPendingText": "Envoi de la commande..."
  },
  "actions": [
    {
      "type": "wait",
      "ms": 1500
    },
    {
      "type": "focusInput"
    },
    {
      "type": "wait",
      "ms": 1200
    },
    {
      "type": "type",
      "text": "/alias say",
      "revealSuggestions": {
        "mode": "commandMatch",
        "activeIndex": 0,
        "suggestions": [
          {
            "name": "/alias say",
            "description": "demande a p'titpote d'envoyer le message"
          }
        ]
      }
    },
    {
      "type": "wait",
      "ms": 400
    },
    {
      "type": "setSlashParams",
      "params": [
        {
          "name": "alias",
          "description": "alias du message"
        }
      ]
    },
    {
      "type": "wait",
      "ms": 800
    },
    {
      "type": "typeSlashParam",
      "param": "alias",
      "text": "welcome"
    },
    {
      "type": "wait",
      "ms": 800
    },
    {
      "type": "pressEnter"
    },
    {
      "type": "applyState",
      "layers": {
        "messages": [
          {
            "author": {
              "name": "P'tit Pote",
              "bot": true,
              "avatarUrl": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote.png"
            },
            "timestamp": "14:10",
            "slashInvocation": {
              "user": {
                "name": "Modo",
                "color": "#5865f2"
              },
              "command": "alias say"
            },
            "interaction": {
              "type": 4,
              "data": {
                "flags": 32768,
                "components": [
                  {
                    "type": 10,
                    "content": "Bienvenue sur le serveur !"
                  }
                ]
              }
            }
          }
        ]
      },
      "holdMs": 2500
    }
  ],
  "output": {
    "directory": "docs/usage/alias",
    "prefix": "alias-say",
    "video": true
  }
}
