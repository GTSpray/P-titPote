        {
            "type": "wait",
            "ms": 1200
        },
        {
            "type": "typeSlashParam",
            "param": "message",
            "text": "Bonjour tout le monde !",
            "msPerChar": 158
        },
        {
            "type": "wait",
            "ms": 800
        },
        {
            "type": "pressEnter"
        },
        {
            "type": "applyState",
            "layers": {
                "messages": [
                    {
                        "author": {
                            "name": "P'tit Pote",
                            "bot": true,
                            "avatarUrl": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote.png"
                        },
                        "timestamp": "14:10",
                        "slashInvocation": {
                            "user": {
                                "name": "Modo",
                                "color": "#5865f2"
                            },
                            "command": "alias set"
                        },
                        "interaction": {
                            "type": 4,
                            "data": {
                                "flags": 32768,
                                "components": [
                                    {
                                        "type": 10,
